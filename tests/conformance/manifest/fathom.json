{
  "provider": "fathom",
  "nangoIntegration": "fathom-relay",
  "adapterPackage": "@relayfile/adapter-fathom",
  "capabilities": {
    "webhook": true,
    "writeback": false,
    "sync": true
  },
  "inbound": [
    {
      "event": "recording.completed",
      "source": "official:https://api-docs.fathom.video/ | nango-template:https://github.com/NangoHQ/integration-templates | local:relayfile-adapters/packages/fathom/src/webhook-normalizer.ts",
      "payload": {
        "recording_id": 123456789,
        "title": "Weekly sync",
        "meeting_title": "Weekly sync",
        "url": "https://fathom.video/rec_123",
        "share_url": "https://fathom.video/share/rec_123",
        "created_at": "2026-06-01T12:00:00Z",
        "default_summary": {
          "template_name": "general",
          "markdown_formatted": "## Summary\nWeekly sync\n"
        },
        "transcript": []
      },
      "expect": {
        "contentIncludes": [
          "title"
        ],
        "paths": [
          "/fathom/recordings/123456789/summary.json"
        ]
      }
    }
  ],
  "writeback": [],
  "sync": [
    {
      "model": "FathomMeeting",
      "syncName": "fetch-meetings",
      "source": "official:https://api-docs.fathom.video/ | nango-template:https://github.com/NangoHQ/integration-templates | local:cloud/nango-integrations/fathom-relay/syncs/fetch-meetings.ts",
      "records": [
        {
          "id": "mtg_123",
          "title": "Weekly sync",
          "started_at": "2026-06-01T12:00:00Z",
          "recorded_by": {
            "email": "sam@example.com"
          }
        }
      ],
      "expect": [
        {
          "path": "/fathom/meetings/mtg_123.json",
          "contentIncludes": [
            "title",
            "started_at"
          ]
        }
      ]
    }
  ]
}
