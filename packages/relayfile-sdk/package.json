{
  "name": "@relayfile/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for relayfile — real-time filesystem for humans and agents",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/testing/mock-system.ts",
      "import": "./src/testing/mock-system.ts",
      "default": "./src/testing/mock-system.ts"
    },
    "./testing/mock-system": {
      "types": "./src/testing/mock-system.ts",
      "import": "./src/testing/mock-system.ts",
      "default": "./src/testing/mock-system.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/testing/mock-system.ts"
  ],
  "scripts": {
    "test": "vitest run",
    "test:e2e": "vitest run src/plugin-system.e2e.test.ts"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentWorkforce/relayfile",
    "directory": "packages/relayfile-sdk"
  },
  "license": "MIT",
  "keywords": [
    "relayfile",
    "filesystem",
    "sync",
    "agent",
    "collaboration"
  ],
  "engines": {
    "node": ">=18"
  }
}
