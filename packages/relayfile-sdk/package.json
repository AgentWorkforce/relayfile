{
  "name": "@relayfile/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for relayfile — real-time filesystem for humans and agents",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentWorkforce/relayfile.git",
    "directory": "packages/relayfile-sdk"
  },
  "license": "MIT",
  "keywords": [
    "relayfile",
    "filesystem",
    "sync",
    "agent",
    "collaboration"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
