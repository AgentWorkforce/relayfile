{
  "name": "@relayfile/agents",
  "version": "0.10.16",
  "description": "Thin agent-framework adapters for Relayfile. One connect() call, ready tools, proven writeback lifecycle.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vercel": {
      "types": "./dist/tools/vercel.d.ts",
      "default": "./dist/tools/vercel.js"
    },
    "./openai": {
      "types": "./dist/tools/openai.d.ts",
      "default": "./dist/tools/openai.js"
    },
    "./langchain": {
      "types": "./dist/tools/langchain.d.ts",
      "default": "./dist/tools/langchain.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentWorkforce/relayfile.git",
    "directory": "packages/agents"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": ">=1",
    "@langchain/anthropic": ">=0.3",
    "@langchain/core": ">=0.3",
    "@langchain/langgraph": ">=0.2",
    "@openai/agents": ">=0",
    "@relayfile/sdk": "^0.10.16",
    "ai": ">=4"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@langchain/anthropic": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^0.3.25",
    "@langchain/langgraph": "^0.2.31",
    "@openai/agents": "^0.0.13",
    "@relayfile/sdk": "0.10.16",
    "@types/node": "^20.19.43",
    "ai": "^4.0.20",
    "typescript": "^5.5.4"
  }
}
