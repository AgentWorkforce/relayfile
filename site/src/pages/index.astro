---
import fs from "node:fs";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import UseCases from "../components/UseCases.astro";
import ApiPreview from "../components/ApiPreview.astro";
import Architecture from "../components/Architecture.astro";
import Footer from "../components/Footer.astro";

const rawContent = fs
  .readFileSync(new URL("../../CONTENT.md", import.meta.url), "utf-8")
  .replace(/\r\n/g, "\n")
  .trim();

const normalize = (value: string) => value.replace(/\r\n/g, "\n").trim();
const escapeRegex = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const stripMarkdown = (value: string) =>
  normalize(value)
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/`([^`]+)`/g, "$1");
const getParagraphs = (value: string) =>
  value
    .split("\n\n")
    .map((entry) => normalize(entry))
    .filter(Boolean);

const getSection = (title: string) => {
  const pattern = new RegExp(
    `^## ${escapeRegex(title)}\\n\\n([\\s\\S]*?)(?=\\n---\\n(?:\\n## |$)|$)`,
    "m"
  );
  const match = rawContent.match(pattern);
  return match ? normalize(match[1]) : "";
};

const getSubsection = (section: string, title: string) => {
  const pattern = new RegExp(
    `^### ${escapeRegex(title)}\\n\\n([\\s\\S]*?)(?=\\n### |$)`,
    "m"
  );
  const match = section.match(pattern);
  return match ? normalize(match[1]) : "";
};

const getLabelValue = (section: string, label: string) => {
  const pattern = new RegExp(`\\*\\*${label}:\\*\\*\\n([^\\n]+)`);
  const match = section.match(pattern);
  return match ? normalize(match[1]) : "";
};

const parseMarkdownLinks = (line: string) =>
  [...line.matchAll(/\[([^\]]+)\]\(([^)]+)\)/g)].map((match) => ({
    label: match[1],
    href: match[2]
  }));

const extractCodeBlocks = (section: string) =>
  [...section.matchAll(/```(\w+)?\n([\s\S]*?)```/g)].map((match) => ({
    language: match[1] || "text",
    code: normalize(match[2])
  }));

const heroSection = getSection("Hero");
const problemSection = getSection('Problem — "Files are the universal interface"');
const solutionSection = getSection('Solution — "RelayFile"');
const useCasesSection = getSection("Use Cases");
const worksSection = getSection("How It Works");
const apiSection = getSection("API Preview");
const architectureSection = getSection("Architecture");
const footerSection = getSection("Footer");

const heroHeadline = getLabelValue(heroSection, "Headline");
const heroSubhead = getLabelValue(heroSection, "Subhead");
const heroCtas = heroSection
  .split("**CTA:**")[1]
  ?.split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line, index) => {
    const [link] = parseMarkdownLinks(line);
    return {
      label: link?.label || "",
      href: link?.href || "#",
      variant: /primary/i.test(line) || index === 0 ? "primary" : "secondary"
    };
  }) || [];

const problemParagraphs = getParagraphs(problemSection).filter((block) => !block.startsWith("- "));
const problemPoints = problemSection
  .split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => line.replace(/^- /, "").trim())
  .map((line) => {
    const match = line.match(/^\*\*([^*]+)\*\*\s*(.*)$/);
    return {
      title: match ? stripMarkdown(match[1]) : "",
      body: stripMarkdown(match ? match[2] : line)
    };
  });

const mountAnywhere = getSubsection(solutionSection, "Mount anywhere");
const revisionControlled = getSubsection(solutionSection, "Revision-controlled");
const programmable = getSubsection(solutionSection, "Programmable");
const programmablePoints = programmable
  .split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => stripMarkdown(line.replace(/^- /, "")));

const solutionFeatures = [
  {
    title: "Mount anywhere",
    body: stripMarkdown(mountAnywhere.split("```")[0] || "")
  },
  {
    title: "Revision-controlled",
    body: stripMarkdown(revisionControlled.split("```")[0] || "")
  }
];
const programmableIntro = stripMarkdown(
  getParagraphs(programmable)
    .filter((block) => !block.startsWith("- ") && !block.startsWith("```"))
    .join("\n\n")
);

const useCaseMatches = [...useCasesSection.matchAll(/### ([^\n]+)\n\n([\s\S]*?)(?=\n### |$)/g)];
const useCaseItems = useCaseMatches.map((match) => ({
  title: normalize(match[1]),
  body: stripMarkdown(match[2].split("```")[0] || "")
}));
const useCaseCodeBlocks = extractCodeBlocks(useCasesSection);

const apiLabels = [...apiSection.matchAll(/\*\*([^*]+)\*\*:/g)].map((match) => match[1]);
const apiSnippets = extractCodeBlocks(apiSection).map((snippet, index) => ({
  label: apiLabels[index] || `Snippet ${index + 1}`,
  language: snippet.language,
  code: snippet.code
}));

const worksSteps = [...worksSection.matchAll(/\d+\.\s+([^\n]+)/g)].map((match) => normalize(match[1]).replace(/`/g, ""));
const architectureOverview = getParagraphs(architectureSection.split("**Key properties:**")[0] || "").map(stripMarkdown);
const propertyItems = architectureSection
  .split("**Key properties:**")[1]
  ?.split("**Production stack:**")[0]
  ?.split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => stripMarkdown(line.replace(/^- /, ""))) || [];
const stackItems = architectureSection
  .split("**Production stack:**")[1]
  ?.split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => stripMarkdown(line.replace(/^- /, ""))) || [];

const footerLinks = parseMarkdownLinks(footerSection.split("\n\n")[0] || "");
const builtBy = parseMarkdownLinks(footerSection.split("Built by ")[1] || "")[0];
---

<Layout
  title="RelayFile | Real-time filesystem for humans and agents"
  description={heroSubhead}
>
  <main class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.16),transparent_30%),linear-gradient(180deg,rgba(9,9,11,1),rgba(9,9,11,0.92))]"></div>
    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-6 sm:px-6 sm:py-10 lg:px-8">
      <Hero headline={heroHeadline} subhead={heroSubhead} ctas={heroCtas} />

      <FeatureGrid
        problemTitle="Files are the universal interface"
        problemBody={problemParagraphs}
        problemPoints={problemPoints}
        solutionTitle="RelayFile"
        features={solutionFeatures}
        programmableIntro={programmableIntro}
        programmablePoints={programmablePoints}
      />

      <UseCases items={useCaseItems} collaborationSnippet={useCaseCodeBlocks[0]?.code} />

      <ApiPreview snippets={apiSnippets} />

      <Architecture
        overview={architectureOverview}
        steps={worksSteps}
        properties={propertyItems}
        stack={stackItems}
      />

      <Footer
        links={footerLinks}
        builtByLabel={builtBy?.label || "Agent Workforce"}
        builtByHref={builtBy?.href || "https://agentworkforce.dev"}
      />
    </div>
  </main>
</Layout>
