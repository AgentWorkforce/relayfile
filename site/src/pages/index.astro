---
import fs from "node:fs";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import UseCases from "../components/UseCases.astro";
import ApiPreview from "../components/ApiPreview.astro";
import Architecture from "../components/Architecture.astro";
import Footer from "../components/Footer.astro";

type CodeBlock = {
  language: string;
  code: string;
};

type ProblemPoint = {
  title: string;
  body: string;
};

type SolutionCard = {
  title: string;
  paragraphs: string[];
  code?: CodeBlock;
};

type UseCase = {
  title: string;
  paragraphs: string[];
  code?: CodeBlock;
};

const contentPath = new URL("../../CONTENT.md", import.meta.url);
const rawContent = fs.readFileSync(contentPath, "utf-8").replace(/\r\n/g, "\n");

const normalize = (value = "") => value.trim();
const escapeRegExp = (value: string) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
const escapeHtml = (value: string) =>
  value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;");

const renderInlineMarkdown = (value: string) =>
  escapeHtml(value)
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");

const getSection = (title: string) => {
  const pattern = new RegExp(`## ${escapeRegExp(title)}\\n\\n([\\s\\S]*?)(?=\\n---\\n\\n## |$)`);
  return normalize(rawContent.match(pattern)?.[1] || "");
};

const getSubsection = (section: string, title: string) => {
  const pattern = new RegExp(`### ${escapeRegExp(title)}\\n\\n([\\s\\S]*?)(?=\\n### |$)`);
  return normalize(section.match(pattern)?.[1] || "");
};

const getLabeledValue = (section: string, label: string) => {
  const pattern = new RegExp(`\\*\\*${escapeRegExp(label)}:\\*\\*\\n([^\\n]+)`);
  return normalize(section.match(pattern)?.[1] || "");
};

const stripCodeBlocks = (value: string) => normalize(value.replace(/```[\s\S]*?```/g, ""));

const extractCodeBlocks = (value: string): CodeBlock[] =>
  [...value.matchAll(/```(\w+)?\n([\s\S]*?)```/g)].map((match) => ({
    language: match[1] || "text",
    code: normalize(match[2])
  }));

const splitParagraphs = (value: string) =>
  stripCodeBlocks(value)
    .split(/\n\n+/)
    .map((paragraph) => normalize(paragraph))
    .filter(Boolean)
    .map((paragraph) => renderInlineMarkdown(paragraph));

const parseMarkdownLinks = (line: string) =>
  [...line.matchAll(/\[([^\]]+)\]\(([^)]+)\)/g)].map((match) => ({
    label: match[1],
    href: match[2]
  }));

const heroSection = getSection("Hero");
const problemSection = getSection('Problem — "Files are the universal interface"');
const solutionSection = getSection('Solution — "RelayFile"');
const useCasesSection = getSection("Use Cases");
const worksSection = getSection("How It Works");
const apiSection = getSection("API Preview");
const architectureSection = getSection("Architecture");
const footerSection = getSection("Footer");

const heroHeadline = getLabeledValue(heroSection, "Headline");
const heroSubhead = getLabeledValue(heroSection, "Subhead");
const heroCtas = normalize(heroSection.split("**CTA:**")[1] || "")
  .split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => {
    const [link] = parseMarkdownLinks(line);
    return {
      label: link?.label || "",
      href: link?.href || "#",
      variant: line.includes("primary") ? "primary" : "secondary"
    } as const;
  });

const problemIntroBlock = normalize(problemSection.split("\n\n- ")[0] || "");
const problemParagraphs = problemIntroBlock
  .split(/\n\n+/)
  .map((paragraph) => normalize(paragraph))
  .filter(Boolean)
  .map((paragraph) => renderInlineMarkdown(paragraph));

const problemPoints: ProblemPoint[] = problemSection
  .split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => line.replace(/^- /, ""))
  .map((line) => {
    const match = line.match(/^\*\*([^*]+)\*\*\s*(.*)$/);
    return {
      title: match?.[1] || "Workflow friction",
      body: renderInlineMarkdown(match?.[2] || line)
    };
  });

const mountAnywhere = getSubsection(solutionSection, "Mount anywhere");
const revisionControlled = getSubsection(solutionSection, "Revision-controlled");
const programmable = getSubsection(solutionSection, "Programmable");

const solutionParagraphs = [
  renderInlineMarkdown(
    "A revision-controlled, programmable filesystem that syncs everywhere. Mount it locally, in the cloud, or in a sandbox. Everyone sees the same files."
  )
];

const toSolutionCard = (title: string, value: string): SolutionCard => ({
  title,
  paragraphs: splitParagraphs(value),
  code: extractCodeBlocks(value)[0]
});

const solutionCards = [
  toSolutionCard("Mount anywhere", mountAnywhere),
  toSolutionCard("Revision-controlled", revisionControlled)
];

const programmableParagraphs = splitParagraphs(
  programmable
    .split("\n")
    .filter((line) => !line.startsWith("- "))
    .join("\n")
);

const programmablePoints = programmable
  .split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => renderInlineMarkdown(line.replace(/^- /, "")));

const useCases: UseCase[] = [...useCasesSection.matchAll(/### ([^\n]+)\n\n([\s\S]*?)(?=\n### |$)/g)].map(
  (match) => {
    const content = normalize(match[2]);
    return {
      title: normalize(match[1]),
      paragraphs: splitParagraphs(content),
      code: extractCodeBlocks(content)[0]
    };
  }
);

const apiLabels = [...apiSection.matchAll(/\*\*([^*]+)\*\*:/g)].map((match) => match[1]);
const apiSnippets = extractCodeBlocks(apiSection).map((snippet, index) => ({
  label: apiLabels[index] || `Snippet ${index + 1}`,
  language: snippet.language,
  code: snippet.code
}));

const worksSteps = [...worksSection.matchAll(/\d+\.\s+([^\n]+)/g)].map((match) =>
  renderInlineMarkdown(normalize(match[1]))
);

const architectureOverview = splitParagraphs(
  architectureSection.split("**Key properties:**")[0] || ""
);

const propertyItems = architectureSection
  .split("**Key properties:**")[1]
  ?.split("**Production stack:**")[0]
  ?.split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => renderInlineMarkdown(line.replace(/^- /, ""))) || [];

const stackItems = architectureSection
  .split("**Production stack:**")[1]
  ?.split("\n")
  .filter((line) => line.startsWith("- "))
  .map((line) => renderInlineMarkdown(line.replace(/^- /, ""))) || [];

const footerLinks = parseMarkdownLinks(footerSection.split("\n\n")[0] || "");
const builtBy = parseMarkdownLinks(footerSection.split("Built by ")[1] || "")[0] || {
  label: "Agent Workforce",
  href: "https://agentworkforce.dev"
};
---

<Layout
  title="RelayFile | Real-time filesystem for humans and agents"
  description={heroSubhead}
>
  <main class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.16),transparent_28%),linear-gradient(180deg,rgba(9,9,11,1),rgba(9,9,11,0.94))]"></div>
    <div class="absolute inset-x-0 top-0 -z-10 h-96 bg-[radial-gradient(circle_at_top,rgba(14,165,233,0.18),transparent_60%)]"></div>

    <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-6 sm:px-6 sm:py-10 lg:px-8">
      <Hero headline={heroHeadline} subhead={heroSubhead} ctas={heroCtas} />

      <FeatureGrid
        problemTitle="Files are the universal interface"
        problemParagraphs={problemParagraphs}
        problemPoints={problemPoints}
        solutionTitle="RelayFile"
        solutionParagraphs={solutionParagraphs}
        solutionCards={solutionCards}
        programmableParagraphs={programmableParagraphs}
        programmablePoints={programmablePoints}
      />

      <UseCases items={useCases} />

      <ApiPreview snippets={apiSnippets} />

      <Architecture
        overview={architectureOverview}
        steps={worksSteps}
        properties={propertyItems}
        stack={stackItems}
      />

      <Footer
        links={footerLinks}
        builtByLabel={builtBy.label}
        builtByHref={builtBy.href}
      />
    </div>
  </main>
</Layout>
