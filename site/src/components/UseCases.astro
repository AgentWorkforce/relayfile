---
interface UseCase {
  title: string;
  paragraphs: string[];
  code?: {
    language: string;
    code: string;
  };
}

interface Props {
  items: UseCase[];
}

const { items } = Astro.props;
---

<section class="surface-panel p-8 sm:p-10">
  <p class="eyebrow">Use Cases</p>
  <h2 class="section-title">Built for human and agent workflows</h2>

  <div class="mt-8 grid gap-5 md:grid-cols-2">
    {
      items.map((item) => (
        <article class="rounded-3xl border border-zinc-800 bg-zinc-950/80 p-6">
          <h3 class="text-xl font-semibold text-zinc-50">{item.title}</h3>
          <div class="content-prose mt-3">
            {
              item.paragraphs.map((paragraph) => (
                <p set:html={paragraph}></p>
              ))
            }
          </div>
          {
            item.code && (
              <div class="code-frame mt-5">
                <div class="code-frame__header">
                  <span>{item.code.language}</span>
                </div>
                <pre class="overflow-x-auto p-5 text-sm leading-7 text-zinc-200"><code>{item.code.code}</code></pre>
              </div>
            )
          }
        </article>
      ))
    }
  </div>
</section>
