---
interface ProblemPoint {
  title: string;
  body: string;
}

interface Feature {
  title: string;
  body: string;
}

interface Props {
  problemTitle: string;
  problemBody: string[];
  problemPoints: ProblemPoint[];
  solutionTitle: string;
  solutionIntro?: string;
  features: Feature[];
  programmableIntro?: string;
  programmablePoints: string[];
}

const {
  problemTitle,
  problemBody,
  problemPoints,
  solutionTitle,
  solutionIntro,
  features,
  programmableIntro,
  programmablePoints
} = Astro.props;
---

<section class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
  <div class="section-shell p-8 sm:p-10">
    <p class="section-heading">Problem</p>
    <h2 class="section-title">{problemTitle}</h2>
    <div class="content-prose mt-6">
      {
        problemBody.map((paragraph) => (
          <p>{paragraph}</p>
        ))
      }
    </div>
    <div class="mt-8 grid gap-4">
      {
        problemPoints.map((point) => (
          <div class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-5">
            <h3 class="text-sm font-semibold text-zinc-100">{point.title}</h3>
            <p class="mt-2 text-sm leading-7 text-zinc-400">{point.body}</p>
          </div>
        ))
      }
    </div>
  </div>

  <div class="space-y-6">
    <article class="section-shell p-8">
      <p class="section-heading">Solution</p>
      <h2 class="section-title">{solutionTitle}</h2>
      {
        solutionIntro && (
          <div class="content-prose mt-6">
            <p>{solutionIntro}</p>
          </div>
        )
      }
    </article>

    {
      features.map((feature) => (
        <article class="section-shell p-7">
          <h3 class="text-xl font-semibold text-zinc-50">{feature.title}</h3>
          <div class="content-prose mt-3">
            <p>{feature.body}</p>
          </div>
        </article>
      ))
    }

    <article class="section-shell p-7">
      <h3 class="text-xl font-semibold text-zinc-50">Programmable by default</h3>
      {
        programmableIntro && (
          <div class="content-prose mt-3">
            <p>{programmableIntro}</p>
          </div>
        )
      }
      <ul class="mt-4 space-y-3 text-sm leading-7 text-zinc-300">
        {
          programmablePoints.map((point) => (
            <li class="flex gap-3">
              <span class="mt-2 h-2 w-2 rounded-full bg-cyan-400"></span>
              <span>{point}</span>
            </li>
          ))
        }
      </ul>
    </article>
  </div>
</section>
