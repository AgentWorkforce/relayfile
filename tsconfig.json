{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "baseUrl": "packages/web",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "lib/**/*.ts",
    "tests/**/*.ts",
    "sst-env.d.ts",
    "packages/web/next-env.d.ts",
    "packages/admin/next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "packages",
    "tests/router.test.ts",
    "tests/proactive-runtime/e2e.test.ts",
    "tests/proactive-runtime/deploy-routes.test.ts"
  ]
}
